# Frontend URL
FRONTEND_URL=http://localhost:5173

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key_here

# Database configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.lrgcfkm.mongodb.net
DB_NAME=database_name_here

# Server configuration
PORT=3000
NODE_ENV=development

# Redis configuration
REDIS_HOST=redis_host_here
REDIS_PASSWORD=redis_password_here
REDIS_PORT=redis_port_here

# TMDB API Key
TMDB_API_KEY=your_tmdb_api_key_here

# Nodemailer configuration
EMAIL_HOST=your_email_host_here
EMAIL_PORT=your_email_port_here
EMAIL_SECURE=false # true for 465, false for other ports
EMAIL_USER=your_email_user_here
EMAIL_PASS=your_email_password_here